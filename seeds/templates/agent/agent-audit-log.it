title: {{log_title}}
meta: | type: template | domain: agent | description: Agent execution audit log capturing session metadata, step-by-step actions, tool invocations, and immutable session history | theme: technical | version: 1.0 | author: IntentText
track: | version: {{log_version}} | by: {{recorded_by}} | note: Session {{session_id}} recorded
---
section: Session Metadata
---
text: Session Details
  *Session ID:* {{session_id}}
  *Agent:* {{agent_name}}
  *Model:* {{model}}
  *Started:* {{session_start}}
  *Ended:* {{session_end}}
  *Duration:* {{session_duration}}
  *Status:* {{session_status}}
  *Trigger:* {{trigger_event}}
---
section: Execution Log
---
text: Step {{step_number}} — {{action}}
  *Timestamp:* {{timestamp}}
  *Tool:* {{tool_used}}
  *Input Summary:* {{input_summary}}
  *Output Summary:* {{output_summary}}
  *Latency:* {{latency}}
  *Tokens:* {{token_count}}
  *Status:* {{status}}
---
section: Resource Usage
---
text: Consumption Summary
  *Total Steps:* {{total_steps}}
  *Total Tokens:* {{total_tokens}}
  *Total Latency:* {{total_latency}}
  *Estimated Cost:* {{estimated_cost}}
  *Tools Invoked:* {{tools_invoked}}
---
section: Outcome
---
text: Result
  {{outcome_summary}}
---
text: Recorded by {{recorded_by}} · {{record_date}}
---
sign: {{recorded_by}} | role: Agent Recorder | at: {{record_date}} | hash: {{document_hash}}
---
freeze: Session {{session_id}} complete — audit log sealed
