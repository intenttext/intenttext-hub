amendment: {{amendment_2_description}} | section: {{amendment_2_section}} | was: {{amendment_2_was}} | now: {{amendment_2_now}} | ref: Amendment #1 | by: {{amendment_by}} | at: {{amendment_date}}
amendment: {{amendment_3_description}} | section: {{amendment_3_section}} | now: {{amendment_3_now}} | ref: Amendment #1 | by: {{amendment_by}} | at: {{amendment_date}}
