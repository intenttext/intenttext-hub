title: {{title}}
meta: | type: template | domain: organization | description: Standalone signature page for multi-document agreements with multiple signatory lines | theme: legal | version: 1.0 | author: IntentText | since: 2.11
summary: {{summary}}
x-layout: font | content: {{font_family}} | size: {{font_size}} | heading: {{heading_font}}
page: {{page_size}} | margins: {{margins}}
