title: Standard Invoice
meta: | type: template | domain: business | description: Standard invoice with line items and tax | theme: corporate | version: 1.0 | author: IntentText
track: | version: 1.0 | by: Finance
---
section: Invoice Details
---
text: Invoice Information
  *Invoice Number:* {{invoice_number}}
  *Date:* {{date}}
  *Due Date:* {{due_date}}
  *Payment Terms:* {{payment_terms}}
---
text: From
  {{company_name}}
  {{company_address}}
  {{company_email}}
---
text: Bill To
  {{client_name}}
  {{client_company}}
  {{client_address}}
  {{client_email}}
---
section: Line Items
---
each: items
  note: {{description}}
    *Quantity:* {{quantity}} · *Unit Price:* {{unit_price}} · *Amount:* {{amount}}
---
section: Totals
---
text: Summary
  *Subtotal:* {{subtotal}}
  *Tax ({{tax_rate}}):* {{tax_amount}}
  *Total Due:* {{total}}
---
text: Payment Instructions
  {{payment_instructions}}
---
sign: {{authorized_by}} | role: Finance Manager | at: {{signed_date}} | hash: {{document_hash}}
---
freeze: Invoice finalized | at: {{freeze_date}} | by: {{authorized_by}}
